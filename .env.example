# =============================================================================
# FIPLA Dashboard — exemple de configuration d'environnement
# Copier ce fichier en `.env` (ou `server/.env` pour le backend) et renseigner
# les valeurs réelles. Aucune valeur sensible ne doit rester dans ce fichier.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — frontend (Vite, exposé côté client)
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# -----------------------------------------------------------------------------
# Supabase — backend (lu par server/index.js et server/stripe/stripeClient.js)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# -----------------------------------------------------------------------------
# Stripe — backend (clé secrète + secret de signature du webhook)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# -----------------------------------------------------------------------------
# Stripe — frontend (base URL optionnelle du proxy API Stripe ; vide = proxy Vite)
# -----------------------------------------------------------------------------
VITE_STRIPE_API_BASE_URL=

# -----------------------------------------------------------------------------
# TaxWare — backend (proxy serveur uniquement, jamais côté client)
# -----------------------------------------------------------------------------
TAXWARE_API_URL=https://taxapi.taxware.ch/api/V1/IncomeAssetTaxDetailed/IncomeAssetTaxDetailed
TAXWARE_USERNAME=your-taxware-username
TAXWARE_PASSWORD=your-taxware-password

# -----------------------------------------------------------------------------
# Serveur Express (server/index.js) — hôte et port d'écoute
# HOST par défaut 127.0.0.1 ; PORT par défaut 3000 (fallback 3002 si libre)
# -----------------------------------------------------------------------------
HOST=127.0.0.1
PORT=3000

# -----------------------------------------------------------------------------
# Environnement d'exécution Node — "development" ou "production"
# Conditionne les logs détaillés et les comportements dev-only
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# -----------------------------------------------------------------------------
# Anthropic — Claude Advisor (backend uniquement, jamais côté client)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# -----------------------------------------------------------------------------
# Frontend — feature flag du pilote "changement de domicile"
# Valeur exacte attendue : "true" pour activer, vide/autre pour désactiver
# -----------------------------------------------------------------------------
VITE_ENABLE_DOMICILE_PILOT=false

# -----------------------------------------------------------------------------
# Debug TaxWare — affiche le bloc "Payload TaxWare détaillé" dans l'UI
# et active les traces console du chemin revenu → payload
# Valeur exacte attendue : "true" pour activer, vide/autre pour désactiver
# Par défaut désactivé en dev et en prod.
# -----------------------------------------------------------------------------
VITE_SHOW_TAXWARE_DEBUG=false
